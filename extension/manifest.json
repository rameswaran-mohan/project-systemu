{
  "name": "sharing_on Omni-Capture",
  "description": "Extracts DOM events to track SaaS actions for sharing_on, and sends the current page or selection to systemu.",
  "version": "1.1",
  "manifest_version": 3,
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:49494/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "systemu"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
