# ─────────────────────────────────────────────────────────────────────────────
# Systemu — Environment Configuration
#
# This file is normally written by install.py.  Edit it by hand only if you
# know which mode you're in.  The SYSTEMU_MODE field at the top is the single
# source of truth — start.sh / start.bat read it and pick the right runtime.
# ─────────────────────────────────────────────────────────────────────────────

# Selected by install.py.  One of: local | docker-local | docker-enterprise
SYSTEMU_MODE=local

# ── API keys (required in all modes) ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here

# ── LLM tier models ──────────────────────────────────────────────────────────
SYSTEMU_TIER1_MODEL=gemini-3.1-flash-lite-preview
SYSTEMU_TIER2_MODEL=gemini-3.1-flash-lite-preview
SYSTEMU_TIER3_MODEL=z-ai/glm-4.5-air:free
SHARING_ON_MODEL=z-ai/glm-4.5-air:free

# ── Behaviour flags (mode-independent) ───────────────────────────────────────
# v0.6.1: renamed from SYSTEMU_AUTO_APPROVE_SCROLLS (the old name lied — it
# auto-picked the first action in EVERY prompt, not just scroll approval).
# When true, notify_user auto-selects actions[0] (the safe-by-default choice).
SYSTEMU_NON_INTERACTIVE=false
# DEV/TESTING ONLY — bypasses all tool security gates.  Never enable in prod.
SYSTEMU_AUTO_FORGE_TOOLS=false

# ── Capture (sharing_on recording) ────────────────────────────────────────
SHARING_ON_SCREENSHOT_INTERVAL=3
SHARING_ON_SCREENSHOT_WIDTH=1280


# =============================================================================
# === local =================================================================
# Native venv on the host.  Daemon + worker run as detached subprocesses.
# Vault and queue both live in ./data/systemu.db (SQLite).
# =============================================================================
SYSTEMU_STORAGE=sqlite
SYSTEMU_DATABASE_URL=sqlite:///./data/systemu.db
SYSTEMU_QUEUE=huey
SYSTEMU_QUEUE_BROKER=sqlite
SYSTEMU_VAULT_DIR=systemu/vault
# Tool execution backend.  Pick one:
#   local   — in-process subprocess on the host (default)
#   docker  — ephemeral Docker container
#   ssh     — remote host over SSH (stub — planned v0.4)
#   wsl     — explicit WSL backend on Windows (stub — planned v0.4)
SYSTEMU_TOOL_BACKEND=local
# The legacy SYSTEMU_USE_DOCKER_SANDBOX boolean was removed in v0.3.
# Use SYSTEMU_TOOL_BACKEND=docker (above) to enable the Docker backend.

# Messaging gateway (optional — leave unset to disable).
# When SHARING_ON_TELEGRAM_BOT_TOKEN is set, the daemon spins up a
# Telegram bot you can use to submit chat tasks, approve scrolls,
# and receive push notifications from anywhere.  Strict allowlist
# enforcement — empty allowlist means refuse to start.
# See docs/messaging.md for setup walkthrough.
SHARING_ON_TELEGRAM_BOT_TOKEN=
SHARING_ON_TELEGRAM_ALLOWED_USER_IDS=
HUEY_WORKERS=4


# =============================================================================
# === docker-local ==========================================================
# docker-compose.  Postgres for the vault, Huey-SQLite for the queue.
# Uncomment to enable; install.py sets these for you.
# =============================================================================
# SYSTEMU_STORAGE=postgres
# SYSTEMU_DATABASE_URL=postgresql://systemu:systemu@postgres-local:5432/systemu
# SYSTEMU_QUEUE=huey
# SYSTEMU_QUEUE_BROKER=sqlite
# HUEY_SQLITE_PATH=/app/data/huey.db
# POSTGRES_USER=systemu
# POSTGRES_PASSWORD=systemu
# POSTGRES_DB=systemu
# HUEY_WORKERS=4
# v0.6.6-a: Postgres host port binding for docker-local mode.
# Default 127.0.0.1:5432 (loopback-only — same security boundary as the
# dashboard's 127.0.0.1:8765).  Required for `sharing_on record` running
# on the host to reach the container's vault for capture-and-analyze.
# To disable: comment out the `ports:` line in docker-compose.yml's
# postgres-local service via a docker-compose.override.yml file.
# SYSTEMU_DB_BIND=127.0.0.1:5432


# =============================================================================
# === docker-enterprise =====================================================
# docker-compose.  Postgres vault, Redis queue broker, scaled workers.
# Uncomment to enable; install.py sets these for you.
# =============================================================================
# SYSTEMU_STORAGE=postgres
# SYSTEMU_DATABASE_URL=postgresql://systemu:CHANGEME@postgres:5432/systemu
# SYSTEMU_QUEUE=huey
# SYSTEMU_QUEUE_BROKER=redis
# SYSTEMU_REDIS_URL=redis://:CHANGEME@redis:6379/0
# REDIS_AUTH=:CHANGEME@      # leave blank if no password (rendered into the URL)
# POSTGRES_USER=systemu
# POSTGRES_PASSWORD=CHANGEME
# POSTGRES_DB=systemu
# REDIS_PASSWORD=CHANGEME
# WORKER_REPLICAS=2
# HUEY_WORKERS=4
# v0.6.6-a: enterprise mode does NOT publish Postgres on the host by default —
# production should keep the DB on the docker-internal network only.
# To opt IN (e.g. for ad-hoc psql sessions from the host), add a ports section
# to the `postgres` service via docker-compose.override.yml.
# SYSTEMU_DB_BIND=


# ── Output dir (Shadow-generated reports / downloads) ────────────────────────
# Docker:   /app/systemu/outputs (set by docker-compose; bind-mounted to ./outputs)
# Native:   ~/Documents (default; override below if you want a different folder)
# SYSTEMU_OUTPUT_DIR=
